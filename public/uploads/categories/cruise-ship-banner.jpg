                                        <button class="btn secondary btn-medium w-100 text-uppercase"
                                            id="contactpBtn">Enquire
                                            Now</button>
                                        <small class="d-block py-3 text-center text-muted">(*) all fields are
                                            mandatory</small>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
