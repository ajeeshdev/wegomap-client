                                        <label class="input-label">First Name*</label>
                                        <input type="text" class="input-1" name="name" data-type="string"
                                            onfocus="setFocus(true)" onblur="setFocus(false)" autocomplete="userInput"/>
                                    </div>
                                    <div class="input-box">
                                        <label class="input-label">Phone Number*</label>
                                        <input type="number" name="phone" class="input-1" data-type="string"
                                            onfocus="setFocus(true)" onblur="setFocus(false)" autocomplete="userPhone"/>
                                    </div>
                                    <div class="input-box">
                                        <label class="input-label">Email</label>
                                        <input type="email" name="email" class="input-1"
                                            onfocus="setFocus(true)" onblur="setFocus(false)" autocomplete="userEmail"/>
                                    </div>
