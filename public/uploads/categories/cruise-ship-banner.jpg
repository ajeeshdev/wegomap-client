    <script type="text/javascript">
       var enqsent = 0;

        $(window).on('load', function () {
            setTimeout(function () {
                // Check if the popup has been closed in this session
                const popupKey = window.location.pathname; // Use the current page's URL as a key
                const isClosed = sessionStorage.getItem(`${popupKey}_closed`);

                if (!isClosed) {
                    // Show the modal popup
                    $('#welcomePopup1').modal('show');

                    // Mark the popup as shown (but not closed)
                    sessionStorage.setItem(popupKey, 'shown');
                }
            }, 10000); // Show the popup after 10 seconds

            // Close event handler
            $('#welcomePopup1').on('hidden.bs.modal', function () {
                // Mark the popup as closed for this session
                const popupKey = window.location.pathname;
                sessionStorage.setItem(`${popupKey}_closed`, 'true');
            });
        });

    </script>
