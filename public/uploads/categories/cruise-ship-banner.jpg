<style type="text/css">
@media screen and (min-width: 575px) {
    .calendar-jicon {
        padding: 0.7em 0.5em 0.7em 0em;
    }
}

/*@media screen and (max-width: 574px) {  
         .calendar-jicon {
            padding: 0.5em 0.5em 0.55em 0.5em; 
            border: 1px solid #dddddd;
         }
      }*/
     .footer-pages-dropdown {
    position: relative;
}

/* Main dropdown container */
.footer-pages-menu {
    display: none;
    position: absolute;
    bottom: 30px;
    left: 0;
    background: #2f86c9; /* HEADER BLUE */
    min-width: 300px;
    padding: 0;
    box-shadow: 0 6px 20px rgba(0,0,0,0.25);
    z-index: 9999;
    border-radius: 4px;
    overflow: hidden;
}

/* Show on hover */
.footer-pages-dropdown:hover .footer-pages-menu {
    display: block;
}

/* List reset */
.footer-pages-menu li {
    list-style: none;
}

/* Links */
.footer-pages-menu li a {
    display: block;
    padding: 12px 18px;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.15);
}

/* Hover effect (slightly darker blue) */
.footer-pages-menu li a:hover {
    background: #1f6fae;
    color: #ffffff;
}

/* Remove last border */
.footer-pages-menu li:last-child a {
    border-bottom: none;
}


/* robot css */
.wa-bot-container{
    position:fixed;
    bottom:20px;
    right:20px;
    text-decoration:none;
    z-index:9999;
    display:flex;
    flex-direction:column;
    align-items:center;
}

/* Chatbot circle */
.wa-bot-wrapper{
    width:72px;
    height:72px;
    background:#ffffff;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    box-shadow:0 8px 18px rgba(0,0,0,0.2);
    /*margin-bottom:10px;*/
    border:2px solid #adadad;
    overflow:hidden;
}

/* Robot image */
.wa-bot-asset{
    width:60px;
    height:60px;
    object-fit:contain;
    display:block;
}

/* Chat button */
.chat-pill{
    padding:10px 28px;
    background:#ffffff;
    color:#0077b6;
    font-weight:600;
    border-radius:40px;
    font-size:14px;
    border:2px solid #dcdcdc;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    animation:blinkBorder 1.5s infinite;
}

.chat-pill:hover{
    background:#f8f8f8;
}

/* Blinking border animation */
@keyframes blinkBorder{

    0%{
        border-color:#25D366;
        box-shadow:0 0 0 0 rgba(37,211,102,0.7);
    }

    50%{
        border-color:#25D366;
        box-shadow:0 0 12px 3px rgba(37,211,102,0.6);
    }

    100%{
        border-color:#dcdcdc;
        box-shadow:0 0 0 0 rgba(37,211,102,0);
    }

}
</style>

